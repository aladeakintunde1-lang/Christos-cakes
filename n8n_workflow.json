{
  "name": "Christos Cakes Automation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "cake-orders",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        300
      ],
      "webhookId": "cake-orders-webhook"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.type }}",
              "value2": "SEND_INVOICE"
            }
          ]
        }
      },
      "name": "Is Invoice Request?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        350,
        300
      ]
    },
    {
      "parameters": {
        "sendTo": "aladeakintunde1@gmail.com",
        "subject": "🎂 New Bespoke Order: {{ $json.customerName }}",
        "message": "<h1>New Order Received</h1><p><strong>Customer:</strong> {{ $json.customerName }}</p><p><strong>Cake Size:</strong> {{ $json.size }}</p><p><strong>Flavor:</strong> {{ $json.flavor }}</p><p><strong>Delivery Date:</strong> {{ $json.deliveryDate }}</p><p><strong>Message on Cake:</strong> {{ $json.messageOnCake }}</p><br><a href=\"{{ $json.adminUrl }}\" style=\"background-color: #000; color: #fff; padding: 10px 20px; text-decoration: none; border-radius: 5px;\">View in Admin Portal</a>",
        "appendAttribution": false,
        "options": {
          "html": true
        }
      },
      "name": "Notify Admin (New Order)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        600,
        450
      ]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "🧾 Your Christos Cakes Invoice - Order #{{ $json.id }}",
        "message": "<h1>Your Invoice is Ready</h1><p>Hi {{ $json.customerName }},</p><p>The baker has reviewed your bespoke cake order and your invoice is now ready.</p><p><strong>Total Amount:</strong> £{{ $json.totalPrice }}</p><br><a href=\"{{ $json.appUrl }}#/invoice/{{ $json.id }}\" style=\"background-color: #db2777; color: #fff; padding: 10px 20px; text-decoration: none; border-radius: 5px;\">View & Pay Invoice</a><br><p>Thank you for choosing Christos Cakes!</p>",
        "appendAttribution": false,
        "options": {
          "html": true
        }
      },
      "name": "Send Client Invoice",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        600,
        150
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        850,
        300
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Is Invoice Request?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Invoice Request?": {
      "main": [
        [
          {
            "node": "Send Client Invoice",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Notify Admin (New Order)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Client Invoice": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notify Admin (New Order)": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {},
  "id": "christos-cakes-automation"
}
